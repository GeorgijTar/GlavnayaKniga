<Window x:Class="GlavnayaKniga.WPF.Views.DepartmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Основная информация -->
            <TextBlock Grid.Row="0" Text="Основная информация" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <!-- Код отдела -->
            <TextBlock Grid.Row="1" Text="Код отдела:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="2" 
                     Text="{Binding Department.Code, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="50"
                     Height="30"/>

            <!-- Наименование -->
            <TextBlock Grid.Row="3" Text="Наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="4" 
                     Text="{Binding Department.Name, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="200"
                     Height="30"/>

            <!-- Полное наименование -->
            <TextBlock Grid.Row="5" Text="Полное наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="6" 
                     Text="{Binding Department.FullName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <!-- Родительский отдел -->
            <TextBlock Grid.Row="7" Text="Родительский отдел:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="8" 
                      ItemsSource="{Binding ParentDepartments}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedParentDepartment}"
                      Margin="0,0,0,10"
                      Height="30"/>

            <!-- Руководитель -->
            <TextBlock Grid.Row="9" Text="Руководитель отдела:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="10" 
                      ItemsSource="{Binding Heads}"
                      DisplayMemberPath="IndividualShortName"
                      SelectedItem="{Binding SelectedHead}"
                      Margin="0,0,0,10"
                      Height="30"/>

            <!-- Контактная информация -->
            <TextBlock Grid.Row="11" Text="Контактная информация" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Телефон:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Department.Phone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"
                             Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Department.Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="100"
                             Height="30"/>
                </StackPanel>
            </Grid>

            <!-- Местоположение -->
            <TextBlock Grid.Row="13" Text="Местоположение:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="14" 
                     Text="{Binding Department.Location, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="200"
                     Height="30"/>

            <!-- Примечание -->
            <TextBlock Grid.Row="15" Text="Примечание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="16" 
                     Text="{Binding Department.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="17" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="18"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>