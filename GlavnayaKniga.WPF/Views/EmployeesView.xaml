<UserControl x:Class="GlavnayaKniga.WPF.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:CanEditVisibilityConverter x:Key="CanEditVisibilityConverter"/>
        <converters:CanTransferVisibilityConverter x:Key="CanTransferVisibilityConverter"/>
        <converters:CanDismissVisibilityConverter x:Key="CanDismissVisibilityConverter"/>
        <converters:EmployeeStatusToColorConverter x:Key="EmployeeStatusToColorConverter"/>
        <converters:EmployeeStatusToTextConverter x:Key="EmployeeStatusToTextConverter"/>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="25"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusActiveStyle" TargetType="Border">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style x:Key="StatusProbationStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style x:Key="StatusLeaveStyle" TargetType="Border">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style x:Key="StatusDismissedStyle" TargetType="Border">
            <Setter Property="Background" Value="#9E9E9E"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Сотрудники" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить сотрудника" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddEmployeeCommand}"
                    Background="#4CAF50"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditEmployeeCommand}"
                    Background="#2196F3"/>
            <Button Content="📋 История" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding ViewHistoryCommand}"
                    Background="#9C27B0"/>
            <Button Content="🔄 Перевод" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding TransferEmployeeCommand}"
                    Background="#FF9800"/>
            <Button Content="📄 Увольнение" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding DismissEmployeeCommand}"
                    Background="#F44336"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding RefreshCommand}"
                    Background="#607D8B"/>
        </WrapPanel>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Padding="5"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 Поиск по ФИО, табельному номеру или должности..." 
                                                             Foreground="Gray" 
                                                             Padding="5,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Фильтр по отделу -->
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding DepartmentFilters}"
                          SelectedItem="{Binding SelectedDepartmentFilter}"
                          Margin="0,0,10,0"
                          Height="30"/>

                <!-- Чекбокс уволенных -->
                <CheckBox Grid.Column="2" 
                          Content="Показывать уволенных" 
                          IsChecked="{Binding IncludeDismissed}"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Таблица сотрудников -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding FilteredEmployees}"
                  SelectedItem="{Binding SelectedEmployee}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  RowDetailsVisibilityMode="VisibleWhenSelected">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Таб.№" 
                                    Binding="{Binding PersonnelNumber}" 
                                    Width="80"/>

                <DataGridTextColumn Header="ФИО" 
                                    Binding="{Binding IndividualShortName}" 
                                    Width="180"/>

                <DataGridTextColumn Header="Должность" 
                                    Binding="{Binding CurrentPositionName}" 
                                    Width="200"/>

                <DataGridTextColumn Header="Отдел" 
                                    Binding="{Binding Department}" 
                                    Width="150"/>

                <DataGridTextColumn Header="Дата приема" 
                                    Binding="{Binding HireDate, StringFormat=dd.MM.yyyy}" 
                                    Width="95"/>               

                <DataGridTemplateColumn Header="Статус" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="5,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Gray"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Active">
                                                <Setter Property="Background" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Probation">
                                                <Setter Property="Background" Value="#FF9800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="OnLeave">
                                                <Setter Property="Background" Value="#2196F3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Dismissed">
                                                <Setter Property="Background" Value="#9E9E9E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusDisplay}" 
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Действия" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="✏️"  VerticalAlignment="Center"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2196F3"
                                        Foreground="White"
                                        Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать"
                                        Visibility="{Binding Status, Converter={StaticResource CanEditVisibilityConverter}}"/>

                                <Button Content="📋"  VerticalAlignment="Center"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#9C27B0"
                                        Foreground="White"
                                        Command="{Binding DataContext.ViewHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="История"/>

                                <Button Content="🔄"  VerticalAlignment="Center"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#FF9800"
                                        Foreground="White"
                                        Command="{Binding DataContext.TransferEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Перевод"
                                        Visibility="{Binding Status, Converter={StaticResource CanTransferVisibilityConverter}}"/>

                                <Button Content="📄"  VerticalAlignment="Center"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#F44336"
                                        Foreground="White"
                                        Command="{Binding DataContext.DismissEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Увольнение"
                                        Visibility="{Binding Status, Converter={StaticResource CanDismissVisibilityConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <!-- Детали строки -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Руководитель:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ManagerName, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Приказ о приеме:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HireOrderNumber, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Личный телефон:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IndividualPhone, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Личный Email:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding IndividualEmail, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Примечание:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Note, TargetNullValue='—'}" 
                                       TextWrapping="Wrap" Margin="0,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>