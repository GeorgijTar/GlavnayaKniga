<UserControl x:Class="GlavnayaKniga.WPF.Views.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Стиль для кнопок на панели инструментов -->
        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- Стиль для выделенного элемента в TreeView -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок экспорта -->
        <Style x:Key="ExportButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolBarButtonStyle}">
            <Setter Property="Background" Value="#2E74B5"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- Шаблон для отображения архивных счетов -->
        <DataTemplate x:Key="ArchivedAccountTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Code}" FontWeight="Bold" Margin="0,0,5,0" Foreground="Gray"/>
                <TextBlock Text="{Binding Name}" Foreground="Gray"/>
                <TextBlock Text=" (Архивный)" Foreground="Gray" FontStyle="Italic" Margin="2,0,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Шаблон для обычных счетов -->
        <DataTemplate x:Key="ActiveAccountTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Code}" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Name}"/>
                <TextBlock Text="{Binding Children.Count, StringFormat=' [{0}]'}" 
                          Foreground="{StaticResource LightTextBrush}"
                          FontSize="11"
                          Margin="2,0,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Шаблон для отображения типа счета -->
        <DataTemplate x:Key="AccountTypeTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding TypeIcon}" Margin="0,0,3,0"/>
                <TextBlock Text="{Binding Type, Converter={StaticResource AccountTypeNameConverter}}" 
                   Foreground="Gray" FontSize="11"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="План счетов" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <!-- Существующие кнопки -->
            <Button Content="➕ Добавить" 
            Style="{StaticResource ToolBarButtonStyle}"
            Command="{Binding AddAccountCommand}"
            Background="#4CAF50"/>
            <Button Content="✏️ Редактировать" 
            Style="{StaticResource ToolBarButtonStyle}"
            Command="{Binding EditAccountCommand}"
            Background="#2196F3"/>
            <Button Content="📦 Архивировать" 
            Style="{StaticResource ToolBarButtonStyle}"
            Background="#FF9800"
            Command="{Binding ArchiveAccountCommand}"/>
            <Button Content="📂 Разархивировать" 
            Style="{StaticResource ToolBarButtonStyle}"
            Background="#9C27B0"
            Command="{Binding UnarchiveAccountCommand}"/>
            <Button Content="🗑️ Удалить" 
            Style="{StaticResource ToolBarButtonStyle}"
            Background="#F44336"
            Command="{Binding DeleteAccountCommand}"/>

            <!-- Разделитель -->
            <Border Width="1" Height="30" Background="#E0E0E0" Margin="5,0"/>

            <!-- Кнопки экспорта -->
            <Button Content="📄 Экспорт в Word" 
            Style="{StaticResource ToolBarButtonStyle}"
            Background="#2E74B5"
            Command="{Binding ExportToWordCommand}"
            ToolTip="Экспортировать все счета в Word"/>
            <Button Content="📄 Экспорт видимые" 
            Style="{StaticResource ToolBarButtonStyle}"
            Background="#5B9BD5"
            Command="{Binding ExportFilteredToWordCommand}"
            ToolTip="Экспортировать только видимые счета в Word"/>

            <!-- Кнопка обновления -->
            <Button Content="🔄 Обновить" 
            Style="{StaticResource ToolBarButtonStyle}"
            Background="#607D8B"
            Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <!-- Фильтры и поиск -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Чекбокс показа архивных -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <CheckBox Content="Показывать архивные счета" 
                              IsChecked="{Binding ShowArchivedAccounts}"
                              VerticalAlignment="Center"
                              Margin="0,0,20,0"/>
                </StackPanel>

                <!-- Поиск -->
                <TextBox Grid.Column="1" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Padding="8,5"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center" TileMode="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 Поиск по коду или наименованию..." 
                                                             Foreground="Gray" 
                                                             Padding="5,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Информация о количестве -->
                <TextBlock Grid.Column="2" 
                           Text="{Binding FilteredAccounts.Count, StringFormat='Показано: {0} счетов'}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource LightTextBrush}"/>
            </Grid>
        </Border>

        <!-- TreeView для иерархии счетов -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <TreeView ItemsSource="{Binding FilteredAccounts}"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      Margin="10,0,10,10"
                      BorderThickness="1"
                      BorderBrush="#E0E0E0"
                      Background="White">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" 
            ToolTip="{Binding FullCode, StringFormat='Полный код: {0}'}">

                            <!-- Иконка типа счета -->
                            <TextBlock Text="{Binding TypeIcon}" Margin="0,0,3,0"/>

                            <!-- Код счета -->
                            <TextBlock Text="{Binding Code}" 
               FontWeight="Bold" 
               Margin="0,0,5,0"
               Foreground="{Binding IsArchived, Converter={StaticResource ArchivedColorConverter}}"/>

                            <!-- Наименование -->
                            <TextBlock Text="{Binding Name}"
               Foreground="{Binding IsArchived, Converter={StaticResource ArchivedColorConverter}}"/>

                            <!-- Тип счета (для синтетических) -->
                            <TextBlock Text="{Binding TypeDisplayName}" 
               Foreground="Gray"
               FontSize="10"
               Margin="10,0,0,0"
               Visibility="{Binding IsSynthetic, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Признак архивного -->
                            <TextBlock Text=" (Архивный)" 
               Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}"
               Foreground="Gray"
               FontStyle="Italic"
               Margin="2,0,0,0"/>

                            <!-- Счетчик дочерних счетов (только для неархивных) -->
                            <TextBlock Text="{Binding Children.Count, StringFormat=' [{0}]'}" 
               Visibility="{Binding IsArchived, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
               Foreground="{StaticResource LightTextBrush}"
               FontSize="11"
               Margin="2,0,0,0"
               ToolTip="Количество дочерних счетов"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>