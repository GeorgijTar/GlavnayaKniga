<UserControl x:Class="GlavnayaKniga.WPF.Views.CounterpartiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:ArchivedColorConverter x:Key="ArchivedColorConverter"/>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style x:Key="StatusActiveStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Green"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusArchivedStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Контрагенты" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddCounterpartyCommand}"
                    Background="#4CAF50"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditCounterpartyCommand}"
                    Background="#2196F3"/>
            <Button Content="📦 Архивировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#FF9800"
                    Command="{Binding ArchiveCounterpartyCommand}"/>
            <Button Content="📂 Разархивировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#9C27B0"
                    Command="{Binding UnarchiveCounterpartyCommand}"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#607D8B"
                    Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Padding="5"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 Поиск по наименованию, ИНН или email..." 
                                                             Foreground="Gray" 
                                                             Padding="5,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Чекбокс показа архивных -->
                <CheckBox Grid.Column="1" 
                          Content="Показывать архивных" 
                          IsChecked="{Binding ShowArchived}"
                          VerticalAlignment="Center"
                          Margin="5,0"/>
            </Grid>
        </Border>

        <!-- Таблица контрагентов -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding FilteredCounterparties}"
                  SelectedItem="{Binding SelectedCounterparty}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  RowDetailsVisibilityMode="VisibleWhenSelected">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Статус" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusDisplay}" 
                       Style="{Binding IsArchived, Converter={StaticResource BooleanToStyleConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn Header="Краткое наименование" 
                                    Binding="{Binding ShortName}" 
                                    Width="350"/>              

                <DataGridTextColumn Header="ИНН" 
                                    Binding="{Binding DisplayINN}" 
                                    Width="100"/>

                <DataGridTextColumn Header="КПП" 
                                    Binding="{Binding DisplayKPP}" 
                                    Width="80"/>

                <DataGridTextColumn Header="Тип" 
                                    Binding="{Binding Type}" 
                                    Width="150"/>

                <DataGridTextColumn Header="Телефон" 
                                    Binding="{Binding Phone}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Email" 
                                    Binding="{Binding Email}" 
                                    Width="150"/>

                
            </DataGrid.Columns>

            <!-- Детали строки -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ОГРН:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OGRN, TargetNullValue='—'}" Margin="0,0,20,5"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Контактное лицо:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ContactPerson, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Юр. адрес:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding LegalAddress, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Факт. адрес:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding ActualAddress, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Примечание:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Note, TargetNullValue='—'}" Margin="0,0,0,5"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>