<Window x:Class="GlavnayaKniga.WPF.Views.IndividualEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="700" Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ФИО -->
            <TextBlock Grid.Row="0" Text="Фамилия:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="1" 
                     Text="{Binding Individual.LastName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="100"/>

            <TextBlock Grid.Row="2" Text="Имя:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="3" 
                     Text="{Binding Individual.FirstName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="100"/>

            <TextBlock Grid.Row="4" Text="Отчество:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="5" 
                     Text="{Binding Individual.MiddleName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="100"/>

            <!-- Дата и место рождения -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Дата рождения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding Individual.BirthDate}"
                                Margin="0,0,0,10"
                                Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Место рождения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.BirthPlace, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="500"/>
                </StackPanel>
            </Grid>

            <!-- Пол и гражданство -->
            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Пол:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox SelectedItem="{Binding Individual.Gender}" Margin="0,0,0,10" Height="30">
                        <ComboBoxItem Content="Мужской"/>
                        <ComboBoxItem Content="Женский"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Гражданство:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.Citizenship, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="100"/>
                </StackPanel>
            </Grid>

            <!-- Адреса -->
            <TextBlock Grid.Row="8" Text="Адрес регистрации:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="9" 
                     Text="{Binding Individual.RegistrationAddress, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <TextBlock Grid.Row="10" Text="Фактический адрес:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="11" 
                     Text="{Binding Individual.ActualAddress, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <!-- Контакты -->
            <Grid Grid.Row="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Телефон:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.Phone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="100"/>
                </StackPanel>
            </Grid>

            <!-- Паспортные данные -->
            <TextBlock Grid.Row="13" Text="Паспортные данные" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Серия:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.PassportSeries, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="10"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Номер:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.PassportNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="20"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Дата выдачи:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding Individual.PassportIssueDate}"
                                Margin="0,0,0,10"
                                Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Код подразделения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.PassportDepartmentCode, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="20"/>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="16" Text="Кем выдан:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="17" 
                     Text="{Binding Individual.PassportIssuedBy, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <!-- ИНН и СНИЛС -->
            <Grid Grid.Row="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="ИНН:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.INN, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="СНИЛС:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Individual.SNILS, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="14"/>
                </StackPanel>
            </Grid>

            <!-- Примечание -->
            <TextBlock Grid.Row="19" Text="Примечание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="20" 
                     Text="{Binding Individual.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="21" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="22"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>