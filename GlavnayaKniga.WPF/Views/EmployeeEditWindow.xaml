<Window x:Class="GlavnayaKniga.WPF.Views.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:controls="clr-namespace:GlavnayaKniga.WPF.Controls"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="750" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="SearchControlStyle" TargetType="controls:IndividualSearchControl">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="PositionSearchStyle" TargetType="controls:PositionSearchControl">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Стиль для элементов статуса с отображением русских названий -->
        <Style x:Key="StatusComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Content" Value="{Binding}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="Active">
                    <Setter Property="Content" Value="Работает"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding}" Value="Probation">
                    <Setter Property="Content" Value="Испытательный срок"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding}" Value="OnLeave">
                    <Setter Property="Content" Value="В отпуске"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding}" Value="Dismissed">
                    <Setter Property="Content" Value="Уволен"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <TextBlock Grid.Row="0" Text="Информация о сотруднике" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

            <!-- Физическое лицо (кастомный контрол) -->
            <TextBlock Grid.Row="1" Text="Физическое лицо:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <controls:IndividualSearchControl 
                Grid.Row="2"
                x:Name="IndividualSearch"
                ItemsSource="{Binding Individuals}"
                SelectedItem="{Binding SelectedIndividual, UpdateSourceTrigger=PropertyChanged}"
                ItemSelected="IndividualSearch_ItemSelected"
                AddCommand="{Binding AddIndividualCommand}"
                EditCommand="{Binding EditIndividualCommand}"
                Style="{StaticResource SearchControlStyle}"/>

            <!-- Табельный номер -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Табельный номер:" FontWeight="SemiBold" Margin="0,0,10,5" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding Employee.PersonnelNumber, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
                         MaxLength="20"
                         Height="30"
                         IsReadOnly="{Binding IsEditMode}"/>
            </Grid>

            <!-- Должность (кастомный контрол) -->
            <TextBlock Grid.Row="4" Text="Должность:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <controls:PositionSearchControl 
                Grid.Row="5"
                x:Name="PositionSearch"
                ItemsSource="{Binding Positions}"
                SelectedItem="{Binding SelectedPosition, UpdateSourceTrigger=PropertyChanged}"
                ItemSelected="PositionSearch_ItemSelected"
                AddCommand="{Binding AddPositionCommand}"
                EditCommand="{Binding EditPositionCommand}"
                Style="{StaticResource PositionSearchStyle}"/>

            <!-- Отдел -->
            <TextBlock Grid.Row="6" Text="Отдел:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="7" 
                      ItemsSource="{Binding Departments}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedDepartment}"
                      Margin="0,0,0,10"
                      Height="30"/>

            <!-- Статус (русифицированный) -->
            <TextBlock Grid.Row="8" Text="Статус:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="9" 
                      ItemsSource="{Binding Statuses}"
                      SelectedItem="{Binding SelectedStatus}"
                      Margin="0,0,0,10"
                      Height="30">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="Active">
                                            <Setter Property="Text" Value="Работает"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="Probation">
                                            <Setter Property="Text" Value="Испытательный срок"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="OnLeave">
                                            <Setter Property="Text" Value="В отпуске"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="Dismissed">
                                            <Setter Property="Text" Value="Уволен"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Дата приема -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Дата приема:" FontWeight="SemiBold" Margin="0,0,10,5" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="1" 
                            SelectedDate="{Binding Employee.HireDate}"
                            Margin="0,0,0,10"
                            Height="30"
                            DisplayDateEnd="{x:Static system:DateTime.Today}"/>
            </Grid>

            <!-- Приказ о приеме -->
            <Grid Grid.Row="11">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Приказ №:" FontWeight="SemiBold" Margin="0,0,10,5" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding Employee.HireOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
                         MaxLength="50"
                         Height="30"/>
            </Grid>

            <!-- Дата приказа -->
            <Grid Grid.Row="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Дата приказа:" FontWeight="SemiBold" Margin="0,0,10,5" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="1" 
                            SelectedDate="{Binding Employee.HireOrderDate}"
                            Margin="0,0,0,10"
                            Height="30"
                            DisplayDateEnd="{x:Static system:DateTime.Today}"/>
            </Grid>

            <!-- Контактные данные (рабочие) -->
            <TextBlock Grid.Row="13" Text="Рабочие контакты" FontWeight="Bold" FontSize="14" Margin="0,10,0,10"/>

            <Grid Grid.Row="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Телефон:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Employee.WorkPhone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"
                             Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Employee.WorkEmail, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="100"
                             Height="30"/>
                </StackPanel>
            </Grid>

            <!-- Руководитель -->
            <TextBlock Grid.Row="15" Text="Руководитель:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="16" 
                      ItemsSource="{Binding Managers}"
                      DisplayMemberPath="IndividualShortName"
                      SelectedItem="{Binding SelectedManager}"
                      Margin="0,0,0,10"
                      Height="30"/>

            <!-- Примечание -->
            <TextBlock Grid.Row="17" Text="Примечание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="18" 
                     Text="{Binding Employee.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="21"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>