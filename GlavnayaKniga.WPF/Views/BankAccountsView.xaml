<UserControl x:Class="GlavnayaKniga.WPF.Views.BankAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style x:Key="StatusActiveStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Green"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusClosedStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Банковские счета" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить счет" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddBankAccountCommand}"
                    Background="#4CAF50"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditBankAccountCommand}"
                    Background="#2196F3"/>
            <Button Content="🗑️ Удалить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#F44336"
                    Command="{Binding DeleteBankAccountCommand}"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#607D8B"
                    Command="{Binding RefreshCommand}"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                     Width="250"
                     Margin="5,0"
                     Padding="5"
                     VerticalAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Text" Value=""/>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍 Поиск по номеру счета или банку..." 
                                                         Foreground="Gray" 
                                                         Padding="5,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </WrapPanel>

        <!-- Таблица банковских счетов -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding BankAccounts}"
                  SelectedItem="{Binding SelectedBankAccount}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  RowDetailsVisibilityMode="VisibleWhenSelected">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Расчетный счет" 
                                    Binding="{Binding AccountNumber}" 
                                    Width="150"/>

                <DataGridTextColumn Header="Банк" 
                                    Binding="{Binding BankName}" 
                                    Width="200"/>

                <DataGridTextColumn Header="БИК" 
                                    Binding="{Binding BIK}" 
                                    Width="80"/>

                <DataGridTextColumn Header="Субсчет" 
                                    Binding="{Binding SubaccountCode}" 
                                    Width="70"/>

                <DataGridTextColumn Header="Валюта" 
                                    Binding="{Binding Currency}" 
                                    Width="60"/>

                <DataGridTextColumn Header="Дата открытия" 
                                    Binding="{Binding OpenDate, StringFormat=dd.MM.yyyy}" 
                                    Width="100"/>

                <DataGridTemplateColumn Header="Статус" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusDisplay}" 
                                       Style="{Binding IsActive, Converter={StaticResource BooleanToStyleConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <!-- Детали строки (показывают период действия и причину закрытия) -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Период действия:" FontWeight="Bold"/>
                                <TextBlock Text="Корр. счет:" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Причина закрытия:" FontWeight="Bold" Margin="0,5,0,0"
                                           Visibility="{Binding IsActive, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding PeriodDisplay}"/>
                                <TextBlock Text="{Binding CorrespondentAccount}" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding CloseReason}" Margin="0,5,0,0"
                                           Visibility="{Binding IsActive, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="3"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>