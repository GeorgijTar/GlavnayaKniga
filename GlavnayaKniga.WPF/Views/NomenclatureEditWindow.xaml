<Window x:Class="GlavnayaKniga.WPF.Views.NomenclatureEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="750" Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Основная информация -->
            <TextBlock Grid.Row="0" Text="Основная информация" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <!-- Наименование -->
            <TextBlock Grid.Row="1" Text="Наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="2" 
                     Text="{Binding Item.Name, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"/>

            <!-- Полное наименование -->
            <TextBlock Grid.Row="3" Text="Полное наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="4" 
                     Text="{Binding Item.FullName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <!-- Артикул и штрих-код -->
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Артикул:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.Article, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"/>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="✕" 
                        Command="{Binding ClearArticleCommand}"
                        Width="25" Height="25"
                        Margin="2,0,5,10"
                        ToolTip="Очистить поле"
                        VerticalAlignment="Bottom"/>

                <StackPanel Grid.Column="2" Margin="5,0,5,0">
                    <TextBlock Text="Штрих-код:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.Barcode, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"/>
                </StackPanel>

                <Button Grid.Column="3" 
                        Content="✕" 
                        Command="{Binding ClearBarcodeCommand}"
                        Width="25" Height="25"
                        Margin="2,0,0,10"
                        ToolTip="Очистить поле"
                        VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Тип и единица измерения -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Тип:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Types}"
                              SelectedItem="{Binding SelectedType}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Единица измерения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Units}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedUnit}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>
            </Grid>

            <!-- Счет учета и счет НДС -->
            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Счет учета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Accounts}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedAccount}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Счет учета НДС:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding VatAccounts}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedVatAccount}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>
            </Grid>

            <!-- Место хранения -->
            <TextBlock Grid.Row="8" Text="Место хранения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <Grid Grid.Row="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" 
                          ItemsSource="{Binding StorageLocations}"
                          DisplayMemberPath="FullPath"
                          SelectedItem="{Binding SelectedStorageLocation}"
                          Margin="0,0,5,10"
                          Height="30"/>
                <Button Grid.Column="1" 
                        Content="✕" 
                        Command="{Binding ClearStorageLocationCommand}"
                        Width="25" Height="25"
                        Margin="2,0,0,10"
                        ToolTip="Сбросить выбор"
                        VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Цены -->
            <TextBlock Grid.Row="10" Text="Цены" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="11">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Цена закупки:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.PurchasePrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Цена продажи:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.SalePrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>
            </Grid>

            <!-- Остатки -->
            <TextBlock Grid.Row="12" Text="Остатки" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="13">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Текущий остаток:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.CurrentStock, StringFormat=N3, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"
                             IsReadOnly="True"
                             Background="#F5F5F5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                    <TextBlock Text="Мин. остаток:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.MinStock, StringFormat=N3, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                    <TextBlock Text="Макс. остаток:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Item.MaxStock, StringFormat=N3, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>
            </Grid>

            <!-- Описание -->
            <TextBlock Grid.Row="14" Text="Описание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="15" 
                     Text="{Binding Item.Description, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="2000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Примечание -->
            <TextBlock Grid.Row="16" Text="Примечание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="17" 
                     Text="{Binding Item.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <!-- Информация о создании/изменении (только для редактирования) -->
            <Border Grid.Row="18" 
                    Background="#F5F5F5" 
                    Padding="10" 
                    CornerRadius="4" 
                    Margin="0,0,0,15"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Создан:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Item.CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Изменен:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Item.UpdatedAt, StringFormat=dd.MM.yyyy HH:mm, TargetNullValue='—'}" Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- Кнопки -->
            <StackPanel Grid.Row="21" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="22"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>