<Window x:Class="GlavnayaKniga.WPF.Views.BankAccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="700" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>

        <Style x:Key="ValidationMessageStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="5,2"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Valid">
                    <Setter Property="Foreground" Value="Green"/>
                </Trigger>
                <Trigger Property="Tag" Value="Invalid">
                    <Setter Property="Foreground" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Номер расчетного счета -->
        <TextBlock Grid.Row="0" Text="Номер расчетного счета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" 
                     Text="{Binding Account.AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,5,5"
                     MaxLength="30"/>
            <Button Grid.Column="1" 
                    Content="Проверить" 
                    Command="{Binding CheckAccountNumberCommand}"
                    Margin="0,0,0,5"
                    Padding="10,3"
                    FontSize="12"/>
        </Grid>
        <TextBlock Grid.Row="2" 
                   Text="{Binding AccountValidationMessage}"
                   Style="{StaticResource ValidationMessageStyle}"
                   Tag="{Binding IsAccountValid, Converter={x:Static converters:BooleanToTagConverter.Instance}}"/>

        <!-- БИК -->
        <TextBlock Grid.Row="3" Text="БИК:" Margin="0,10,0,5" FontWeight="SemiBold"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" 
                     Text="{Binding Account.BIK, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,5,5"
                     MaxLength="9"/>
            <Button Grid.Column="1" 
                    Content="Найти банк" 
                    Command="{Binding CheckBikCommand}"
                    Margin="0,0,0,5"
                    Padding="10,3"
                    FontSize="12"/>
        </Grid>
        <TextBlock Grid.Row="5" 
                   Text="{Binding BikValidationMessage}"
                   Style="{StaticResource ValidationMessageStyle}"
                   Tag="{Binding IsBikValid, Converter={x:Static converters:BooleanToTagConverter.Instance}}"/>

        <!-- Наименование банка (заполняется автоматически) -->
        <TextBlock Grid.Row="6" Text="Наименование банка:" Margin="0,10,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="7" 
                 Text="{Binding Account.BankName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 Margin="0,0,0,10"
                 MaxLength="200"
                 IsReadOnly="True"
                 Background="#F5F5F5"/>

        <!-- Корреспондентский счет (заполняется автоматически) -->
        <TextBlock Grid.Row="8" Text="Корреспондентский счет:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="9" 
                 Text="{Binding Account.CorrespondentAccount, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 Margin="0,0,0,10"
                 MaxLength="30"
                 IsReadOnly="True"
                 Background="#F5F5F5"/>

        <!-- Тип банковского счета -->
        <TextBlock Grid.Row="10" Text="Тип счета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="11" 
                  ItemsSource="{Binding AccountTypes}"
                  SelectedItem="{Binding SelectedAccountType}"
                  Margin="0,0,0,10"
                  Height="30"/>

        <!-- Субсчет учета -->
        <TextBlock Grid.Row="12" Text="Субсчет учета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="13" 
                  ItemsSource="{Binding Subaccounts}"
                  DisplayMemberPath="DisplayName"
                  SelectedItem="{Binding SelectedSubaccount}"
                  Margin="0,0,0,10"
                  Height="30"/>

        <!-- Дата открытия -->
        <TextBlock Grid.Row="14" Text="Дата открытия:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <DatePicker Grid.Row="15" 
                    SelectedDate="{Binding Account.OpenDate}"
                    Margin="0,0,0,10"
                    Height="30"
                    FirstDayOfWeek="Monday"/>

        <!-- Статус счета (активен/закрыт) -->
        <CheckBox Grid.Row="16" 
                  Content="Счет закрыт" 
                  IsChecked="{Binding IsAccountClosed}"
                  Margin="0,0,0,10"
                  FontWeight="SemiBold"/>

        <!-- Блок информации о закрытии (видим только если счет закрыт) -->
        <Border Grid.Row="17" 
                Background="#FFF9E6" 
                Padding="10" 
                Margin="0,0,0,10"
                CornerRadius="4"
                BorderBrush="#FFE0B2"
                BorderThickness="1"
                Visibility="{Binding IsAccountClosed, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Дата закрытия:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker Grid.Row="1" 
                            SelectedDate="{Binding Account.CloseDate}"
                            Margin="0,0,0,8"
                            Height="30"
                            FirstDayOfWeek="Monday"/>

                <TextBlock Grid.Row="2" Text="Причина закрытия:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox Grid.Row="3" 
                         Text="{Binding Account.CloseReason, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,0"
                         MaxLength="500"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="40"/>
            </Grid>
        </Border>

        <!-- Валюта и активность (скрыто если счет закрыт) -->
        <Grid Grid.Row="18" Margin="0,0,0,15" 
              Visibility="{Binding IsAccountClosed, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" 
            Visibility="{Binding IsAccountClosed, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                <TextBlock Text="Валюта:" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="CurrencyComboBox" 
              SelectedItem="{Binding Account.Currency}"
              Width="80">
                    <ComboBoxItem Content="RUB" IsSelected="True"/>
                    <ComboBoxItem Content="USD"/>
                    <ComboBoxItem Content="EUR"/>
                </ComboBox>
            </StackPanel>

            <TextBlock Grid.Column="1" 
                       Text="Счет активен" 
                       Foreground="Green"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
            <Button Content="Отмена" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="21"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="6">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>