<Window x:Class="GlavnayaKniga.WPF.Views.AssetTypeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="300" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Наименование -->
        <TextBlock Grid.Row="0" Text="Наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="1" 
                 Text="{Binding Type.Name, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 MaxLength="200"/>

        <!-- Описание -->
        <TextBlock Grid.Row="2" Text="Описание:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="3" 
                 Text="{Binding Type.Description, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,20"
                 MaxLength="500"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="60"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
            <Button Content="Отмена" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="6"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="6">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>