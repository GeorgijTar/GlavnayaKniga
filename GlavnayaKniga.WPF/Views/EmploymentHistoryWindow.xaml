<Window x:Class="GlavnayaKniga.WPF.Views.EmploymentHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="История трудоустройства" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="ChangeTypeHireStyle" TargetType="Border">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style x:Key="ChangeTypeTransferStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style x:Key="ChangeTypeDismissalStyle" TargetType="Border">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о сотруднике -->
        <Border Grid.Row="0" 
                Background="#F5F5F5" 
                Padding="10" 
                CornerRadius="4" 
                Margin="0,0,0,15"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Сотрудник:" FontWeight="Bold"/>
                    <TextBlock Text="Таб. номер:" FontWeight="Bold" Margin="0,5,0,0"/>
                    <TextBlock Text="Должность:" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Employee.IndividualShortName}"/>
                    <TextBlock Text="{Binding Employee.PersonnelNumber}" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding Employee.CurrentPositionName}" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Заголовок таблицы -->
        <TextBlock Grid.Row="1" Text="История кадровых изменений" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <!-- Таблица истории -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding History}"
                  SelectedItem="{Binding SelectedHistory}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Тип" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="5,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Gray"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChangeType}" Value="Hire">
                                                <Setter Property="Background" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ChangeType}" Value="Transfer">
                                                <Setter Property="Background" Value="#FF9800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ChangeType}" Value="Dismissal">
                                                <Setter Property="Background" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ChangeTypeDisplay}" 
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Дата начала" 
                                    Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Дата окончания" 
                                    Binding="{Binding EndDate, StringFormat=dd.MM.yyyy, TargetNullValue='—'}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Должность" 
                                    Binding="{Binding PositionName}" 
                                    Width="200"/>

                <DataGridTextColumn Header="Приказ №" 
                                    Binding="{Binding OrderNumber}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Дата приказа" 
                                    Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Основание/Причина" 
                                    Binding="{Binding Reason}" 
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка закрытия -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Закрыть" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CloseCommand}"
                    IsDefault="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="6">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>