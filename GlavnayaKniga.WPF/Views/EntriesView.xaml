<UserControl x:Class="GlavnayaKniga.WPF.Views.EntriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Стиль для кнопок на панели инструментов -->
        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- Стиль для кнопок периодов -->
        <Style x:Key="PeriodButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Стиль для текста суммы (выравнивание вправо) -->
        <Style x:Key="RightAlignedTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>

        <!-- Стиль для ячейки суммы -->
        <Style x:Key="AmountCellStyle" TargetType="DataGridCell">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Right" 
                                            VerticalAlignment="Center"
                                            Margin="5,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Конвертер для форматирования суммы -->
        <converters:AmountToColorConverter x:Key="AmountToColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Журнал проводок" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddEntryCommand}"
                    Background="#4CAF50"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditEntryCommand}"
                    Background="#2196F3"/>
            <Button Content="🗑️ Удалить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#F44336"
                    Command="{Binding DeleteEntryCommand}"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#607D8B"
                    Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Период -->
                <TextBlock Grid.Column="0" Text="Период:" VerticalAlignment="Center" Margin="5,0,10,0"/>

                <DatePicker Grid.Column="1" 
                            SelectedDate="{Binding StartDate}"
                            Width="120"
                            Margin="0,0,5,0"
                            FirstDayOfWeek="Monday"/>

                <TextBlock Grid.Column="2" Text="—" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <DatePicker Grid.Column="3" 
                            SelectedDate="{Binding EndDate}"
                            Width="120"
                            Margin="0,0,10,0"
                            FirstDayOfWeek="Monday"/>

                <!-- Кнопки быстрых периодов -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Content="Текущий месяц" 
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetCurrentMonthCommand}"/>
                    <Button Content="Прошлый месяц" 
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetPreviousMonthCommand}"/>
                    <Button Content="Квартал" 
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetCurrentQuarterCommand}"/>
                    <Button Content="Год" 
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetCurrentYearCommand}"/>
                </StackPanel>

                <!-- Фильтр по счету -->
                <ComboBox Grid.Column="5" 
                          ItemsSource="{Binding Accounts}"
                          DisplayMemberPath="DisplayName"
                          SelectedItem="{Binding SelectedAccount}"
                          Margin="5,0,0,0"
                          MinWidth="200"/>
            </Grid>
        </Border>

        <!-- DataGrid проводок -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10,0,10,10"
                  RowDetailsVisibilityMode="VisibleWhenSelected"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Columns>
                <!-- Дата -->
                <DataGridTextColumn Header="Дата" 
                                    Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                    Width="100"
                                    SortMemberPath="Date"/>

                <!-- Дебет -->
                <DataGridTemplateColumn Header="Дебет" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" ToolTip="{Binding DebitAccountName}">
                                <TextBlock Text="{Binding DebitAccountCode}" 
                                           FontWeight="Bold" 
                                           Margin="0,0,5,0"/>
                                <!--<TextBlock Text="{Binding DebitAccountName}" 
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="120"/>-->
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Кредит -->
                <DataGridTemplateColumn Header="Кредит" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" ToolTip="{Binding CreditAccountName}">
                                <TextBlock Text="{Binding CreditAccountCode}" 
                                           FontWeight="Bold" 
                                           Margin="0,0,5,0"/>
                                <!--<TextBlock Text="{Binding CreditAccountName}" 
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="120"/>-->
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Сумма -->
                <DataGridTextColumn Header="Сумма" 
                                    Binding="{Binding Amount, StringFormat=N2}"
                                    Width="120"
                                    ElementStyle="{StaticResource RightAlignedTextStyle}">
                    <!--<DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>-->
                </DataGridTextColumn>

                <!-- Основание -->
                <DataGridTextColumn Header="Основание" 
                                    Binding="{Binding BasisName}"
                                    Width="250"/>

                <!-- Примечание -->
                <DataGridTextColumn Header="Примечание" 
                                    Binding="{Binding Note}"
                                    Width="*"/>
            </DataGrid.Columns>

            <!-- Детали строки (показываются при выборе) -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#FFF9E6" Padding="10" BorderBrush="#FFE0B2" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Дата создания:" FontWeight="Bold"/>
                                <TextBlock Text="Дата изменения:" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Полный код дебета:" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBlock Text="Полный код кредита:" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"/>
                                <TextBlock Text="{Binding UpdatedAt, StringFormat=dd.MM.yyyy HH:mm, TargetNullValue='—'}" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding DisplayDebit, TargetNullValue='—'}" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding DisplayCredit, TargetNullValue='—'}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Нижняя панель с итогами -->
        <Border Grid.Row="4" 
                Background="#E3F2FD" 
                Padding="10" 
                Margin="10"
                CornerRadius="4"
                BorderBrush="#90CAF9"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Всего проводок:" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" 
                           Text="{Binding Entries.Count}" 
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Общая сумма:" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" 
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{Binding TotalAmount, Converter={StaticResource AmountToColorConverter}}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="5"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>