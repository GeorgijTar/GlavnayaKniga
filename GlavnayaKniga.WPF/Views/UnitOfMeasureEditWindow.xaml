<Window x:Class="GlavnayaKniga.WPF.Views.UnitOfMeasureEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Код -->
            <TextBlock Grid.Row="0" Text="Код (ОКЕИ):" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="1" 
                     Text="{Binding Unit.Code, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="10"
                     Height="30"/>

            <!-- Краткое наименование -->
            <TextBlock Grid.Row="2" Text="Краткое наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="3" 
                     Text="{Binding Unit.ShortName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="20"
                     Height="30"/>

            <!-- Полное наименование -->
            <TextBlock Grid.Row="4" Text="Полное наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="5" 
                     Text="{Binding Unit.FullName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="100"
                     Height="30"/>

            <!-- Международный код -->
            <TextBlock Grid.Row="6" Text="Международный код:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="7" 
                     Text="{Binding Unit.InternationalCode, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="10"
                     Height="30"/>

            <!-- Описание -->
            <TextBlock Grid.Row="8" Text="Описание:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="9" 
                     Text="{Binding Unit.Description, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="11"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>