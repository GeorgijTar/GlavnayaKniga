<Window x:Class="GlavnayaKniga.WPF.Views.AssetEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="700" Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Основная информация -->
            <TextBlock Grid.Row="0" Text="Основная информация" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <!-- Наименование -->
            <TextBlock Grid.Row="1" Text="Наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="2" 
                     Text="{Binding Asset.Name, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"/>

            <!-- Тип объекта и счет учета -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Тип объекта:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AssetTypes}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedAssetType}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Счет учета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Accounts}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedAccount}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>
            </Grid>

            <!-- Идентификационные номера -->
            <TextBlock Grid.Row="4" Text="Идентификационные номера" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Инвентарный номер:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.InventoryNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Регистрационный номер:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.RegistrationNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Заводской номер:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.SerialNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="100"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Модель:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.Model, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="200"/>
                </StackPanel>
            </Grid>

            <!-- Характеристики -->
            <TextBlock Grid.Row="7" Text="Характеристики" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Производитель:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.Manufacturer, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="200"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                    <TextBlock Text="Год выпуска:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Years}"
                              SelectedItem="{Binding SelectedYear}"
                              Margin="0,0,0,10"
                              Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                    <TextBlock Text="Местоположение:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.Location, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="200"/>
                </StackPanel>
            </Grid>

            <!-- Даты -->
            <TextBlock Grid.Row="9" Text="Даты" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Дата приобретения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding Asset.PurchaseDate}"
                                Margin="0,0,0,10"
                                Height="30"
                                DisplayDateEnd="{x:Static system:DateTime.Today}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                    <TextBlock Text="Дата ввода:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding Asset.CommissioningDate}"
                                Margin="0,0,0,10"
                                Height="30"
                                DisplayDateEnd="{x:Static system:DateTime.Today}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                    <TextBlock Text="Дата списания:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding Asset.DecommissioningDate}"
                                Margin="0,0,0,10"
                                Height="30"/>
                </StackPanel>
            </Grid>

            <!-- Стоимость -->
            <TextBlock Grid.Row="11" Text="Стоимость" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Первоначальная стоимость:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.InitialCost, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Остаточная стоимость:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Asset.ResidualValue, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>
            </Grid>

            <!-- Ответственное лицо -->
            <TextBlock Grid.Row="13" Text="Ответственное лицо" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <StackPanel Grid.Row="14">
                <ComboBox ItemsSource="{Binding ResponsiblePersons}"
                          DisplayMemberPath="ShortName"
                          SelectedItem="{Binding SelectedResponsiblePerson}"
                          Margin="0,0,0,10"
                          Height="30"/>
            </StackPanel>

            <!-- Примечание -->
            <TextBlock Grid.Row="15" Text="Примечание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="16" 
                     Text="{Binding Asset.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="21"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>