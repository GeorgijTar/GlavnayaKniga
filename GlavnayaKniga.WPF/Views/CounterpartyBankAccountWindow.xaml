<Window x:Class="GlavnayaKniga.WPF.Views.CounterpartyBankAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="600" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:BooleanToTagConverter x:Key="BooleanToTagConverter"/>

        <Style x:Key="ValidationMessageStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="5,2"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Valid">
                    <Setter Property="Foreground" Value="Green"/>
                </Trigger>
                <Trigger Property="Tag" Value="Invalid">
                    <Setter Property="Foreground" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Номер счета -->
            <TextBlock Grid.Row="0" Text="Номер счета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" 
                         Text="{Binding Account.AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,5,5"
                         MaxLength="20"/>
                <Button Grid.Column="1" 
                        Content="Проверить" 
                        Command="{Binding CheckAccountNumberCommand}"
                        Margin="0,0,0,5"
                        Padding="10,3"
                        FontSize="12"
                        MinWidth="70"/>
            </Grid>
            <TextBlock Grid.Row="2" 
                       Text="{Binding AccountValidationMessage}"
                       Style="{StaticResource ValidationMessageStyle}"
                       Tag="{Binding IsAccountValid, Converter={StaticResource BooleanToTagConverter}}"/>

            <!-- БИК -->
            <TextBlock Grid.Row="3" Text="БИК:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" 
                         Text="{Binding Account.BIK, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,5,5"
                         MaxLength="9"/>
                <Button Grid.Column="1" 
                        Content="Найти банк" 
                        Command="{Binding CheckBikCommand}"
                        Margin="0,0,0,5"
                        Padding="10,3"
                        FontSize="12"
                        MinWidth="70"/>
            </Grid>
            <TextBlock Grid.Row="5" 
                       Text="{Binding BikValidationMessage}"
                       Style="{StaticResource ValidationMessageStyle}"
                       Tag="{Binding IsBikValid, Converter={StaticResource BooleanToTagConverter}}"/>

            <!-- Наименование банка (заполняется автоматически) -->
            <TextBlock Grid.Row="6" Text="Наименование банка:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="7" 
                     Text="{Binding Account.BankName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     Margin="0,0,0,10"
                     MaxLength="200"
                     IsReadOnly="True"
                     Background="#F5F5F5"/>

            <!-- Корреспондентский счет (заполняется автоматически) -->
            <TextBlock Grid.Row="8" Text="Корреспондентский счет:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="9" 
                     Text="{Binding Account.CorrespondentAccount, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     Margin="0,0,0,10"
                     MaxLength="20"
                     IsReadOnly="True"
                     Background="#F5F5F5"/>

            <!-- Валюта -->
            <TextBlock Grid.Row="10" Text="Валюта:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="11" 
                      SelectedItem="{Binding Account.Currency}"
                      Margin="0,0,0,10"
                      Height="30">
                <ComboBoxItem Content="RUB" IsSelected="True"/>
                <ComboBoxItem Content="USD"/>
                <ComboBoxItem Content="EUR"/>
            </ComboBox>

            <!-- Основной счет -->
            <CheckBox Grid.Row="12" 
                      Content="Основной счет (использовать по умолчанию)" 
                      IsChecked="{Binding Account.IsDefault}"
                      Margin="0,0,0,15"
                      FontWeight="SemiBold"/>

            <!-- Примечание -->
            <TextBlock Grid.Row="13" Text="Примечание:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="14" 
                     Text="{Binding Account.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="16"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>