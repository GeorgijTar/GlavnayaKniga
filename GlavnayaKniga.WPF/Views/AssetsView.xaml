<UserControl x:Class="GlavnayaKniga.WPF.Views.AssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             xmlns:local="clr-namespace:GlavnayaKniga.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:BooleanToStyleConverter x:Key="BooleanToStyleConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style x:Key="GroupHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="AssetItemStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="InventoryBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Объекты (основные средства и оборудование)" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить объект" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddAssetCommand}"
                    Background="#4CAF50"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditAssetCommand}"
                    Background="#2196F3"/>
            <Button Content="📦 Архивировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#FF9800"
                    Command="{Binding ArchiveAssetCommand}"/>
            <Button Content="📂 Разархивировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#9C27B0"
                    Command="{Binding UnarchiveAssetCommand}"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#607D8B"
                    Command="{Binding RefreshCommand}"/>
            <Button Content="📋 Типы объектов" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#5C6BC0"
                    Command="{Binding ManageAssetTypesCommand}"/>
        </WrapPanel>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Padding="5"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 Поиск по наименованию, инвентарному или регистрационному номеру..." 
                                                             Foreground="Gray" 
                                                             Padding="5,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Фильтр по типу -->
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding AssetTypes}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedAssetType}"
                          Margin="0,0,10,0"
                          Height="30"/>

                <!-- Чекбокс архивных и переключение вида -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <CheckBox Content="Показывать архивные" 
                              IsChecked="{Binding ShowArchived}"
                              VerticalAlignment="Center"
                              Margin="0,0,20,0"/>

                    <RadioButton Content="Группировка" 
                                 IsChecked="{Binding IsGroupedView}"
                                 GroupName="ViewMode"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>

                    <RadioButton Content="Таблица" 
                                 IsChecked="{Binding IsGroupedView, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                 GroupName="ViewMode"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Группированный вид -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsGroupedView, Converter={StaticResource BooleanToVisibilityConverter}}">

            <StackPanel Margin="10,0,10,10">
                <ItemsControl ItemsSource="{Binding AssetGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,15">
                                <!-- Заголовок группы (тип объекта) -->
                                <Border Style="{StaticResource GroupHeaderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding AssetType.Name}" 
                                                       FontSize="16" 
                                                       FontWeight="Bold"/>
                                            <Border Background="#FF9800" 
                                                    CornerRadius="10" 
                                                    Padding="5,2" 
                                                    Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Count}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding AssetType.Description}" 
                                                   Foreground="Gray"
                                                   FontStyle="Italic"/>
                                    </Grid>
                                </Border>

                                <!-- Список объектов данного типа -->
                                <ItemsControl ItemsSource="{Binding Assets}" Margin="20,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource AssetItemStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Основная информация -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                                                                Orientation="Horizontal" Margin="0,0,0,5">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontSize="14" 
                                                                   FontWeight="Bold"/>

                                                        <Border Style="{StaticResource InventoryBadgeStyle}"
                                                                Visibility="{Binding InventoryNumber, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding InventoryNumber}" 
                                                                       Foreground="White"
                                                                       FontSize="11"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Детали -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                                                        <TextBlock Text="Рег.№:" FontWeight="Bold" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding RegistrationNumber, TargetNullValue='—'}" 
                                                                   Foreground="Gray" Margin="0,0,15,0"/>

                                                        <TextBlock Text="Год:" FontWeight="Bold" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding YearDisplay}" 
                                                                   Foreground="Gray" Margin="0,0,15,0"/>

                                                        <TextBlock Text="Модель:" FontWeight="Bold" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding Model, TargetNullValue='—'}" 
                                                                   Foreground="Gray" Margin="0,0,15,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock Text="Стоимость:" FontWeight="Bold" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding CostDisplay}" 
                                                                   Foreground="Green" Margin="0,0,15,0"/>

                                                        <TextBlock Text="Ответств.:" FontWeight="Bold" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding ResponsibleDisplay}" 
                                                                   Foreground="Gray"/>
                                                    </StackPanel>

                                                    <!-- Кнопки действий -->
                                                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="✏️" 
                                                                Command="{Binding DataContext.EditAssetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="#2196F3"
                                                                Foreground="White"
                                                                Width="25" Height="25"
                                                                Margin="2"
                                                                ToolTip="Редактировать"
                                                                BorderThickness="0"
                                                                Cursor="Hand"/>
                                                        <Button Content="📦" 
                                                                Command="{Binding DataContext.ArchiveAssetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="#FF9800"
                                                                Foreground="White"
                                                                Width="25" Height="25"
                                                                Margin="2"
                                                                ToolTip="Архивировать"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                Visibility="{Binding IsArchived, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                                        <Button Content="📂" 
                                                                Command="{Binding DataContext.UnarchiveAssetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="#9C27B0"
                                                                Foreground="White"
                                                                Width="25" Height="25"
                                                                Margin="2"
                                                                ToolTip="Разархивировать"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Табличный вид (альтернативный) -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding AssetGroups}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  RowDetailsVisibilityMode="VisibleWhenSelected"
                  Visibility="{Binding IsGroupedView, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" 
                                    Binding="{Binding Name}" 
                                    Width="250"/>

                <DataGridTextColumn Header="Тип" 
                                    Binding="{Binding AssetTypeName}" 
                                    Width="150"/>

                <DataGridTextColumn Header="Инв.№" 
                                    Binding="{Binding InventoryNumber}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Рег.№" 
                                    Binding="{Binding RegistrationNumber}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Год" 
                                    Binding="{Binding YearDisplay}" 
                                    Width="60"/>

                <DataGridTextColumn Header="Стоимость" 
                                    Binding="{Binding CostDisplay}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Ответственный" 
                                    Binding="{Binding ResponsibleDisplay}" 
                                    Width="150"/>

                <DataGridTemplateColumn Header="Статус" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusDisplay}" 
                                       Style="{Binding IsArchived, Converter={StaticResource BooleanToStyleConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>