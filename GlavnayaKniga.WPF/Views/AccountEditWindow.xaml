<Window x:Class="GlavnayaKniga.WPF.Views.AccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:domain="clr-namespace:GlavnayaKniga.Domain.Entities;assembly=GlavnayaKniga.Domain"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="520" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:AccountTypeNameConverter x:Key="AccountTypeNameConverter"/>
        <converters:AccountTypeDescriptionConverter x:Key="AccountTypeDescriptionConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Код счета -->
        <TextBlock Grid.Row="0" Text="Код счета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="1" 
                 Text="{Binding Account.Code, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 MaxLength="20"
                 IsReadOnly="{Binding IsEditMode}"
                 Background="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>

        <!-- Наименование -->
        <TextBlock Grid.Row="2" Text="Наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="3" 
                 Text="{Binding Account.Name, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 MaxLength="200"
                 AcceptsReturn="False"
                 TextWrapping="Wrap"/>

        <!-- Родительский счет -->
        <TextBlock Grid.Row="4" Text="Родительский счет:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="5" 
                  ItemsSource="{Binding ParentAccounts}"
                  DisplayMemberPath="DisplayName"
                  SelectedItem="{Binding SelectedParentAccount}"
                  Margin="0,0,0,10"
                  IsEditable="True"
                  IsTextSearchEnabled="True"
                  Height="30">
            <ComboBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ComboBox.ItemsPanel>
        </ComboBox>

        <!-- Тип счета -->
        <TextBlock Grid.Row="6" Text="Тип счета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="7" 
                  ItemsSource="{Binding AccountTypes}"
                  SelectedItem="{Binding SelectedAccountType}"
                  Margin="0,0,0,10"
                  Height="30"
                  IsEnabled="{Binding IsEditMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Converter={StaticResource AccountTypeNameConverter}}" Margin="0,0,5,0" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Converter={StaticResource AccountTypeDescriptionConverter}}" 
                                   Foreground="Gray" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Флаг синтетического счета -->
        <CheckBox Grid.Row="8" 
                  Content="Синтетический счет (счет первого порядка)"
                  IsChecked="{Binding IsSynthetic}"
                  Margin="0,0,0,15"
                  IsEnabled="{Binding IsEditMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                  FontWeight="SemiBold"/>

        <!-- Информация о типе счета -->
       

        <!-- Предпросмотр -->
        <Border Grid.Row="10" 
                Background="#F5F5F5" 
                Padding="10" 
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Предпросмотр:" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Account.Code}" FontWeight="Bold" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding Account.Name}"/>
                    <TextBlock Text=" (" Margin="5,0,0,0"/>
                    <TextBlock Text="{Binding SelectedAccountType, Converter={StaticResource AccountTypeNameConverter}}"/>
                    <TextBlock Text=")"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
            <Button Content="Отмена" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="13"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="6">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>