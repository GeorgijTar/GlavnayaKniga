<Window x:Class="GlavnayaKniga.WPF.Views.ReceiptViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="Просмотр документа поступления" Height="700" Width="1500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <Style x:Key="InfoGridStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="MaxHeight" Value="400"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="35"/>
        </Style>

        <Style x:Key="NumericColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Auto"
                  PanningMode="Both">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="Документ поступления" FontWeight="Bold" FontSize="20" Margin="0,0,0,15"/>

            <!-- Информация о документе -->
            <Border Grid.Row="1" Style="{StaticResource InfoGridStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Document.Number}" Margin="0,0,20,5"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Document.Date, StringFormat=dd.MM.yyyy}" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата учета:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Document.AccountingDate, StringFormat=dd.MM.yyyy}" Margin="0,0,20,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Статус:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <Border Grid.Row="1" Grid.Column="3" 
                            Background="{Binding Document.Status, Converter={StaticResource StatusToColorConverter}}"
                            CornerRadius="3"
                            Padding="5,2"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Document.StatusDisplay}" 
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Контрагент:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding ContractorInfo}" Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- Детальная информация -->
            <Border Grid.Row="2" Style="{StaticResource InfoGridStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Счет учета:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Document.CreditAccountDisplay}" Margin="0,0,20,5"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Основание:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Document.Basis, TargetNullValue='—'}" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Договор:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Document.ContractNumber, TargetNullValue='—'}" Margin="0,0,20,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Дата договора:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Document.ContractDate, StringFormat=dd.MM.yyyy, TargetNullValue='—'}" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Места хранения:" FontWeight="SemiBold" Margin="0,0,10,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding StorageLocationsSummary, TargetNullValue='—'}" 
                               TextWrapping="Wrap" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Примечание:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Document.Note, TargetNullValue='—'}" 
                               TextWrapping="Wrap" Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- Информация о УПД и счете-фактуре -->
            <Border Grid.Row="3" Style="{StaticResource InfoGridStyle}" 
                    Visibility="{Binding Document.IsUPD, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Универсальный передаточный документ (УПД)" 
                               FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,20,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Счет-фактура №:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Document.InvoiceNumber}" Margin="0,0,20,0"/>
                        <TextBlock Text="от:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Document.InvoiceDate, StringFormat=dd.MM.yyyy}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Таблица строк документа -->
            <TextBlock Grid.Row="4" Text="Строки документа" Style="{StaticResource SectionHeaderStyle}"/>

            <DataGrid Grid.Row="4" 
                      ItemsSource="{Binding Items}"
                      Style="{StaticResource DataGridStyle}"
                      Margin="0,40,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding LineNumber}" Width="40"/>
                    <DataGridTextColumn Header="Номенклатура" Binding="{Binding NomenclatureName}" Width="200"/>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding NomenclatureArticle}" Width="80"/>
                    <DataGridTextColumn Header="Ед. изм." Binding="{Binding NomenclatureUnit}" Width="70"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=N3}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Сумма без НДС" Binding="{Binding Amount, StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="НДС,%" Binding="{Binding VatRate, StringFormat=N0}" Width="60"/>
                    <DataGridTextColumn Header="Сумма НДС" Binding="{Binding VatAmount, StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Сумма с НДС" Binding="{Binding AmountWithVat, StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Счет учета" Binding="{Binding DebitAccountCode}" Width="80"/>
                    <DataGridTextColumn Header="Счет НДС" Binding="{Binding VatAccountCode}" Width="80"/>
                    <DataGridTextColumn Header="Место хранения" Binding="{Binding StorageLocationName}" Width="120"/>
                    <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Итоги -->
            <Border Grid.Row="5" Background="#E3F2FD" Padding="15" CornerRadius="4" Margin="0,10,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="1" Text="Итого:" FontWeight="Bold" FontSize="16" Margin="0,0,20,0" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Сумма без НДС:" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#2196F3"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="НДС:" FontWeight="SemiBold" Margin="20,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalVatAmount, StringFormat=N2}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#FF9800"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Всего:" FontWeight="SemiBold" Margin="20,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAmountWithVat, StringFormat=N2}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Кнопка закрытия -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,100,0,0">
                <Button Content="Закрыть" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CloseCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="100"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="6"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>