<Window x:Class="GlavnayaKniga.WPF.Views.EntryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Дата проводки -->
        <TextBlock Grid.Row="0" Text="Дата проводки:" Margin="0,0,0,5"/>
        <DatePicker Grid.Row="1" 
                    SelectedDate="{Binding Entry.Date}"
                    Margin="0,0,0,10"
                    DisplayDateEnd="{x:Static system:DateTime.Today}"
                    FirstDayOfWeek="Monday"/>

        <!-- Дебет счета -->
        <TextBlock Grid.Row="2" Text="Счет дебета:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="3" 
                  ItemsSource="{Binding Accounts}"
                  DisplayMemberPath="DisplayName"
                  SelectedItem="{Binding SelectedDebitAccount}"
                  Margin="0,0,0,10"
                  IsEditable="True"
                  IsTextSearchEnabled="True">
            <ComboBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ComboBox.ItemsPanel>
        </ComboBox>

        <!-- Кредит счета -->
        <TextBlock Grid.Row="4" Text="Счет кредита:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="5" 
                  ItemsSource="{Binding Accounts}"
                  DisplayMemberPath="DisplayName"
                  SelectedItem="{Binding SelectedCreditAccount}"
                  Margin="0,0,0,10"
                  IsEditable="True"
                  IsTextSearchEnabled="True">
            <ComboBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ComboBox.ItemsPanel>
        </ComboBox>

        <!-- Сумма -->
        <TextBlock Grid.Row="6" Text="Сумма:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="7" 
                 Text="{Binding Entry.Amount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 PreviewTextInput="TextBox_PreviewTextInput"
                 MaxLength="15"/>

        <!-- Основание -->
        <TextBlock Grid.Row="8" Text="Основание:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="9" 
                  ItemsSource="{Binding Bases}"
                  DisplayMemberPath="Name"
                  SelectedItem="{Binding SelectedBasis}"
                  Margin="0,0,0,10"/>

        <!-- Примечание -->
        <TextBlock Grid.Row="10" Text="Примечание:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="11" 
                 Text="{Binding Entry.Note, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,20"
                 MaxLength="500"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="60"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Margin="5"
                    MinWidth="80"/>
            <Button Content="Отмена" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="5"
                    MinWidth="80"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="13"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>