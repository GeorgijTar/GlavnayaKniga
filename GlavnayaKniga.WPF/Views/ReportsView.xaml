<UserControl x:Class="GlavnayaKniga.WPF.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             xmlns:dtos="clr-namespace:GlavnayaKniga.Application.DTOs;assembly=GlavnayaKniga.Application"
             xmlns:local="clr-namespace:GlavnayaKniga.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Конвертеры -->
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <!-- Стили для заголовков разделов -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource SubHeaderStyle}">
            <Setter Property="Margin" Value="10,15,10,10"/>
        </Style>

        <!-- Стиль для кнопок отчетов -->
        <Style x:Key="ReportButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Стиль для экспортных кнопок -->
        <Style x:Key="ExportButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Background" Value="#2E74B5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style x:Key="ReportDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="MaxHeight" Value="400"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>

        <!-- Стиль для числовых ячеек -->
        <Style x:Key="NumericCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Конвертер для отступа в зависимости от уровня иерархии -->
        <local:LevelToIndentConverter x:Key="LevelToIndentConverter"/>

        <!-- Конвертер для форматирования периода -->
        <local:DateRangeFormatter x:Key="DateRangeFormatter"/>

        <!-- Шаблон для иерархического отображения в анализе счета -->
        <HierarchicalDataTemplate x:Key="AccountAnalysisTemplate" 
                                  DataType="{x:Type dtos:AccountAnalysisDto}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="{Binding Level, Converter={StaticResource LevelToIndentConverter}}">
                <TextBlock Text="{Binding AccountCode}" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding AccountName}" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding OpeningBalance, StringFormat=N2}" 
                           Style="{StaticResource NumericCellStyle}"
                           Width="100"/>
                <TextBlock Text="{Binding TotalDebitTurnover, StringFormat=N2}" 
                           Style="{StaticResource NumericCellStyle}"
                           Width="100"/>
                <TextBlock Text="{Binding TotalCreditTurnover, StringFormat=N2}" 
                           Style="{StaticResource NumericCellStyle}"
                           Width="100"/>
                <TextBlock Text="{Binding ClosingBalance, StringFormat=N2}" 
                           Style="{StaticResource NumericCellStyle}"
                           Width="100"
                           FontWeight="Bold"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <TabControl Margin="10">
        <!-- Вкладка: Анализ счета -->
        <TabItem Header="Анализ счета">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <!-- Параметры отчета -->
                    <Border Background="#F5F5F5" Padding="15" CornerRadius="4" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Строка 1: Счет и период -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Счет:" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                      ItemsSource="{Binding Accounts}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedAccountForAnalysis}"
                                      Margin="5" Width="180"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Период:" VerticalAlignment="Center" Margin="5"/>
                            <DatePicker Grid.Row="0" Grid.Column="3" 
                                        SelectedDate="{Binding StartDate}"
                                        Margin="5" Width="120"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="—" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="5" 
                                        SelectedDate="{Binding EndDate}"
                                        Margin="5" Width="120"/>

                            <!-- Строка 2: Кнопки -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Сформировать" 
                                        Style="{StaticResource ReportButtonStyle}"
                                        Command="{Binding GenerateAccountAnalysisCommand}"/>
                                <Button Content="Экспорт в Excel" 
                                        Style="{StaticResource ExportButtonStyle}"
                                        Command="{Binding ExportAccountAnalysisToExcelCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Результат анализа -->
                    <Border Background="White" Padding="15" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1"
                            Visibility="{Binding AccountAnalysisHierarchy.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedAccountForAnalysis.DisplayName, StringFormat='Анализ счета {0}'}" 
                                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding StartDate, StringFormat='За период с dd.MM.yyyy г. по {0} г.', Converter={StaticResource DateRangeFormatter}}" 
                                       Margin="0,0,0,20"/>

                            <!-- Заголовки колонок -->
                            <Grid Margin="10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Счет" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Нач. сальдо" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Оборот Дт" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="Оборот Кт" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Кон. сальдо" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- TreeView для иерархического отображения -->
                            <TreeView ItemsSource="{Binding AccountAnalysisHierarchy}"
                                      ItemTemplate="{StaticResource AccountAnalysisTemplate}"
                                      BorderThickness="0"
                                      MaxHeight="400"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>

                            <!-- Детальный анализ выбранного счета -->
                            <Border Background="#F9F9F9" Padding="10" Margin="10,0" CornerRadius="4" 
                                    Visibility="{Binding AccountAnalysis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Детальная информация по счету:" FontWeight="Bold" Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Начальное сальдо:" Margin="5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AccountAnalysis.OpeningBalance, StringFormat=N2}" 
                                                   Style="{StaticResource NumericCellStyle}"/>

                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Оборот дебет:" Margin="20,5,5,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding AccountAnalysis.TotalDebitTurnover, StringFormat=N2}" 
                                                   Style="{StaticResource NumericCellStyle}"/>

                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Оборот кредит:" Margin="20,5,5,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding AccountAnalysis.TotalCreditTurnover, StringFormat=N2}" 
                                                   Style="{StaticResource NumericCellStyle}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Конечное сальдо:" Margin="5" FontWeight="Bold"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AccountAnalysis.ClosingBalance, StringFormat=N2}" 
                                                   Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                    </Grid>

                                    <!-- Таблица корреспонденций -->
                                    <TextBlock Text="Корреспонденции:" FontWeight="Bold" Margin="0,10,0,5"/>
                                    <DataGrid ItemsSource="{Binding AccountAnalysis.CorrespondingAccounts}"
                                              Style="{StaticResource ReportDataGridStyle}"
                                              Margin="0,0,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Кор. счет" Binding="{Binding AccountCode}" Width="100"/>
                                            <DataGridTextColumn Header="Наименование" Binding="{Binding AccountName}" Width="200"/>
                                            <DataGridTextColumn Header="Дебет" Binding="{Binding DebitAmount, StringFormat=N2}" Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Кредит" Binding="{Binding CreditAmount, StringFormat=N2}" Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Вкладка: Оборотно-сальдовая ведомость -->
        <TabItem Header="Оборотно-сальдовая ведомость">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <!-- Параметры отчета -->
                    <Border Background="#F5F5F5" Padding="15" CornerRadius="4" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Строка 1: Период -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Период:" VerticalAlignment="Center" Margin="5"/>
                            <DatePicker Grid.Row="0" Grid.Column="1" 
                                        SelectedDate="{Binding StartDate}"
                                        Margin="5" Width="120"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="—" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="3" 
                                        SelectedDate="{Binding EndDate}"
                                        Margin="5" Width="120"/>

                            <!-- Строка 2: Выбор счета -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Счет:" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" 
                                      ItemsSource="{Binding Accounts}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedAccountForBalanceSheet}"
                                      IsEnabled="{Binding ElementName=AllAccountsCheckBox, Path=IsChecked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                      Margin="5" Width="180"/>

                            <CheckBox Grid.Row="1" Grid.Column="2" 
                                      x:Name="AllAccountsCheckBox"
                                      Content="По всем счетам" 
                                      IsChecked="{Binding AllAccountsBalanceSheet}"
                                      VerticalAlignment="Center" Margin="5"/>

                            <!-- Строка 3: Кнопки -->
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Сформировать" 
                                        Style="{StaticResource ReportButtonStyle}"
                                        Command="{Binding GenerateBalanceSheetCommand}"/>
                                <Button Content="Экспорт в Excel" 
                                        Style="{StaticResource ExportButtonStyle}"
                                        Command="{Binding ExportBalanceSheetToExcelCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Результат ОСВ -->
                    <Border Background="White" Padding="15" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1"
                            Visibility="{Binding BalanceSheetRows.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Оборотно-сальдовая ведомость" 
                                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding StartDate, StringFormat='За период с dd.MM.yyyy г. по {0} г.', Converter={StaticResource DateRangeFormatter}}" 
                                       Margin="0,0,0,20"/>

                            <!-- Таблица ОСВ -->
                            <DataGrid ItemsSource="{Binding BalanceSheetRows}"
                                      Style="{StaticResource ReportDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Счет" Binding="{Binding AccountCode}" Width="100"/>
                                    <DataGridTextColumn Header="Наименование" Binding="{Binding AccountName}" Width="250"/>

                                    <DataGridTextColumn Header="Нач. сальдо (Дт)" Binding="{Binding OpeningBalanceDebit, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Нач. сальдо (Кт)" Binding="{Binding OpeningBalanceCredit, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Оборот (Дт)" Binding="{Binding TurnoverDebit, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Оборот (Кт)" Binding="{Binding TurnoverCredit, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Кон. сальдо (Дт)" Binding="{Binding ClosingBalanceDebit, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Кон. сальдо (Кт)" Binding="{Binding ClosingBalanceCredit, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Итоги -->
                            <Border Background="#E3F2FD" Padding="10" Margin="10,0" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="350"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="ИТОГО:" FontWeight="Bold" FontSize="14"/>

                                    <TextBlock Grid.Column="1" Text="{Binding BalanceSheet.TotalOpeningBalanceDebit, StringFormat=N2}" 
                                               Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding BalanceSheet.TotalOpeningBalanceCredit, StringFormat=N2}" 
                                               Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="{Binding BalanceSheet.TotalTurnoverDebit, StringFormat=N2}" 
                                               Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="{Binding BalanceSheet.TotalTurnoverCredit, StringFormat=N2}" 
                                               Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Вкладка: Главная книга -->
        <TabItem Header="Главная книга">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <!-- Параметры отчета -->
                    <Border Background="#F5F5F5" Padding="15" CornerRadius="4" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Строка 1: Счет и период -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Счет:" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                      ItemsSource="{Binding Accounts}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedAccountForGeneralLedger}"
                                      Margin="5" Width="180"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Период:" VerticalAlignment="Center" Margin="5"/>
                            <DatePicker Grid.Row="0" Grid.Column="3" 
                                        SelectedDate="{Binding StartDate}"
                                        Margin="5" Width="120"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="—" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="5" 
                                        SelectedDate="{Binding EndDate}"
                                        Margin="5" Width="120"/>

                            <!-- Строка 2: Кнопки -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Сформировать" 
                                        Style="{StaticResource ReportButtonStyle}"
                                        Command="{Binding GenerateGeneralLedgerCommand}"/>
                                <Button Content="Экспорт в Excel" 
                                        Style="{StaticResource ExportButtonStyle}"
                                        Command="{Binding ExportGeneralLedgerToExcelCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Результат Главной книги -->
                    <Border Background="White" Padding="15" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1"
                            Visibility="{Binding GeneralLedgerEntries.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedAccountForGeneralLedger.DisplayName, StringFormat='Главная книга - счет {0}'}" 
                                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding StartDate, StringFormat='За период с dd.MM.yyyy г. по {0} г.', Converter={StaticResource DateRangeFormatter}}" 
                                       Margin="0,0,0,20"/>

                            <!-- Сальдо на начало -->
                            <Border Background="#FFF9C4" Padding="10" Margin="0,0,0,10" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Сальдо на начало периода:" FontWeight="Bold" Margin="0,0,20,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GeneralLedgerOpeningBalance, StringFormat=N2}" 
                                               Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                </Grid>
                            </Border>

                            <!-- Таблица операций -->
                            <DataGrid ItemsSource="{Binding GeneralLedgerEntries}"
                                      Style="{StaticResource ReportDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                                    <DataGridTextColumn Header="Операция" Binding="{Binding Operation}" Width="300"/>
                                    <DataGridTextColumn Header="Кор. счет" Binding="{Binding CorrespondingAccountCode}" Width="100"/>
                                    <DataGridTextColumn Header="Дебет" Binding="{Binding DebitAmount, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Кредит" Binding="{Binding CreditAmount, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Сальдо" Binding="{Binding Balance, StringFormat=N2}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NumericCellStyle}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Сальдо на конец -->
                            <Border Background="#E8F5E8" Padding="10" Margin="10,10,10,0" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Сальдо на конец периода:" FontWeight="Bold" Margin="0,0,20,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GeneralLedgerClosingBalance, StringFormat=N2}" 
                                               Style="{StaticResource NumericCellStyle}" FontWeight="Bold"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>