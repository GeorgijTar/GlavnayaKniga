<Window x:Class="GlavnayaKniga.WPF.Views.CounterpartyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        Title="{Binding Title}" Height="750" Width="750"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>

        <Style x:Key="BankAccountDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="MaxHeight" Value="200"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Основная информация -->
            <TextBlock Grid.Row="0" Text="Основная информация" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <!-- Полное наименование -->
            <TextBlock Grid.Row="1" Text="Полное наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="2" 
                     Text="{Binding Counterparty.FullName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"/>

            <!-- Краткое наименование -->
            <TextBlock Grid.Row="3" Text="Краткое наименование:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="4" 
                     Text="{Binding Counterparty.ShortName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="200"/>

            <!-- Тип контрагента -->
            <TextBlock Grid.Row="5" Text="Тип контрагента:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="6" 
                      ItemsSource="{Binding CounterpartyTypes}"
                      SelectedItem="{Binding SelectedType}"
                      Margin="0,0,0,10"
                      Height="30"/>

            <!-- Реквизиты -->
            <TextBlock Grid.Row="7" Text="Реквизиты" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="ИНН:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Counterparty.INN, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 MaxLength="12"/>
                </StackPanel>

                <Button Grid.Column="1" 
            Content="🔍 Загрузить" 
            Command="{Binding LoadFromCheckoCommand}"
            Margin="5,0,5,10"
            Padding="10,5"
            VerticalAlignment="Bottom"
            Background="#2196F3"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            ToolTip="Загрузить данные из ЕГРЮЛ/ЕГРИП по ИНН"/>

                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                    <TextBlock Text="КПП:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Counterparty.KPP, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 MaxLength="9"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="ОГРН/ОГРНИП:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Counterparty.OGRN, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="15"/>
                </StackPanel>
            </Grid>

            <!-- Контактная информация -->
            <TextBlock Grid.Row="10" Text="Контактная информация" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <Grid Grid.Row="11">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Телефон:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Counterparty.Phone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="50"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Counterparty.Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="100"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Контактное лицо:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Counterparty.ContactPerson, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             MaxLength="200"/>
                </StackPanel>
            </Grid>

            <!-- Адреса -->
            <TextBlock Grid.Row="13" Text="Адреса" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

            <TextBlock Grid.Row="14" Text="Юридический адрес:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="15" 
                     Text="{Binding Counterparty.LegalAddress, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <TextBlock Grid.Row="16" Text="Фактический адрес:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="17" 
                     Text="{Binding Counterparty.ActualAddress, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     MaxLength="500"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"/>

            <!-- Банковские счета -->
            <Grid Grid.Row="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Банковские счета" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,10">
                    <Button Content="➕ Добавить" 
                            Command="{Binding AddBankAccountCommand}"
                            Margin="2"
                            Padding="10,5"
                            FontSize="12"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="✏️ Ред." 
                            Command="{Binding EditBankAccountCommand}"
                            Margin="2"
                            Padding="10,5"
                            FontSize="12"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="🗑️ Удалить" 
                            Command="{Binding DeleteBankAccountCommand}"
                            Margin="2"
                            Padding="10,5"
                            FontSize="12"
                            Background="#F44336"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- DataGrid для банковских счетов -->
            <DataGrid Grid.Row="19" 
                      ItemsSource="{Binding BankAccounts}"
                      SelectedItem="{Binding SelectedBankAccount}"
                      Style="{StaticResource BankAccountDataGridStyle}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ счета" 
                                        Binding="{Binding AccountNumber}" 
                                        Width="150"/>

                    <DataGridTextColumn Header="Банк" 
                                        Binding="{Binding BankName}" 
                                        Width="200"/>

                    <DataGridTextColumn Header="БИК" 
                                        Binding="{Binding BIK}" 
                                        Width="80"/>

                    <DataGridTextColumn Header="Валюта" 
                                        Binding="{Binding Currency}" 
                                        Width="60"/>

                    <DataGridTemplateColumn Header="Осн." Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="✓" 
                                           Foreground="Green" 
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Примечание" 
                                        Binding="{Binding Note}" 
                                        Width="*"/>
                </DataGrid.Columns>

                <!-- Детали строки для банковского счета -->
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border Background="#FFF9E6" Padding="5" BorderBrush="#FFE0B2" BorderThickness="1">
                            <TextBlock Text="{Binding CorrespondentAccount, StringFormat='Корр. счет: {0}'}" 
                                       FontSize="11"
                                       Foreground="#FF9800"/>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>

            <!-- Примечание -->
            <TextBlock Grid.Row="20" Text="Примечание:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="21" 
                     Text="{Binding Counterparty.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="22" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="23"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>