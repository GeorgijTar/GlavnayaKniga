<UserControl x:Class="GlavnayaKniga.WPF.Views.StorageLocationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             xmlns:dtos="clr-namespace:GlavnayaKniga.Application.DTOs;assembly=GlavnayaKniga.Application"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BooleanToStyleConverter x:Key="BooleanToStyleConverter"/>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="False"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон для иерархического отображения мест хранения -->
        <HierarchicalDataTemplate x:Key="LocationTemplate" 
                                  DataType="{x:Type dtos:StorageLocationDto}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" ToolTip="{Binding FullPath}">
                <TextBlock Text="{Binding Code}" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Name}"/>
                <TextBlock Text=" (архивный)" 
                           Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Foreground="Gray"
                           FontStyle="Italic"
                           Margin="5,0,0,0"/>
                <TextBlock Text="{Binding Children.Count, StringFormat=' [{0}]'}" 
                           Foreground="{StaticResource LightTextBrush}"
                           FontSize="11"
                           Margin="5,0,0,0"
                           ToolTip="Количество дочерних мест"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Места хранения" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddLocationCommand}"
                    Background="#4CAF50"/>
            <Button Content="➕ Добавить дочернее" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddChildLocationCommand}"
                    Background="#FF9800"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditLocationCommand}"
                    Background="#2196F3"/>
            <Button Content="📦 Архивировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#F44336"
                    Command="{Binding ArchiveLocationCommand}"/>
            <Button Content="📂 Разархивировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#9C27B0"
                    Command="{Binding UnarchiveLocationCommand}"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#607D8B"
                    Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Padding="5"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 Поиск по коду, наименованию или адресу..." 
                                                             Foreground="Gray" 
                                                             Padding="5,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Переключение режима отображения -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                    <RadioButton Content="Дерево" 
                                 IsChecked="{Binding ShowTreeView}"
                                 GroupName="ViewMode"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>
                    <RadioButton Content="Таблица" 
                                 IsChecked="{Binding ShowTreeView, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                 GroupName="ViewMode"
                                 VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Чекбокс архивных -->
                <CheckBox Grid.Column="2" 
                          Content="Показывать архивные" 
                          IsChecked="{Binding ShowArchived}"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Древовидный режим -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowTreeView, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TreeView ItemsSource="{Binding FilteredLocations}"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      ItemTemplate="{StaticResource LocationTemplate}"
                      Margin="10"
                      BorderThickness="1"
                      BorderBrush="#E0E0E0"
                      Background="White">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource TreeViewItemStyle}"/>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </ScrollViewer>

        <!-- Табличный режим -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding FilteredLocations}"
                  SelectedItem="{Binding SelectedLocation}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  RowDetailsVisibilityMode="VisibleWhenSelected"
                  Visibility="{Binding ShowTreeView, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" 
                                    Binding="{Binding Code}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Наименование" 
                                    Binding="{Binding Name}" 
                                    Width="200"/>

                <DataGridTextColumn Header="Тип" 
                                    Binding="{Binding TypeDisplay}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Родитель" 
                                    Binding="{Binding ParentName}" 
                                    Width="150"/>

                <DataGridTextColumn Header="Адрес" 
                                    Binding="{Binding Address}" 
                                    Width="200"/>

                <DataGridTextColumn Header="Площадь" 
                                    Binding="{Binding AreaDisplay}" 
                                    Width="80"/>

                <DataGridTextColumn Header="Вместимость" 
                                    Binding="{Binding CapacityDisplay}" 
                                    Width="80"/>

                <DataGridTextColumn Header="Ответственный" 
                                    Binding="{Binding ResponsibleDisplay}" 
                                    Width="150"/>

                <DataGridTemplateColumn Header="Статус" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusDisplay}" 
                                       Style="{Binding IsArchived, Converter={StaticResource BooleanToStyleConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <!-- Детали строки -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Полный путь:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FullPath}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description, TargetNullValue='—'}" 
                                       TextWrapping="Wrap" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Температурный режим:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TemperatureRegime, TargetNullValue='—'}" Margin="0,0,0,5"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>