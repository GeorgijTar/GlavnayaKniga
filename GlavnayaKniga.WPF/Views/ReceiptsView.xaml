<UserControl x:Class="GlavnayaKniga.WPF.Views.ReceiptsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="25"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumericColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Поступления товаров, работ, услуг" 
                   Style="{StaticResource HeaderStyle}"
                   Margin="10,5"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="10,0,10,10">
            <Button Content="➕ Добавить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding AddReceiptCommand}"
                    Background="#4CAF50"/>
            <Button Content="👁️ Просмотр" 
                        Style="{StaticResource ToolBarButtonStyle}"
                        Background="#607D8B"
                        Foreground="White"
                        Command="{Binding DataContext.ViewReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        ToolTip="Просмотр"
                        Margin="2"/>
            <Button Content="✏️ Редактировать" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Command="{Binding EditReceiptCommand}"
                    Background="#2196F3"/>
            <Button Content="🗑️ Удалить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#F44336"
                    Command="{Binding DeleteReceiptCommand}"/>
            <Button Content="✅ Провести" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#4CAF50"
                    Command="{Binding PostReceiptCommand}"/>
            <Button Content="↩️ Отменить проведение" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#FF9800"
                    Command="{Binding UnpostReceiptCommand}"/>
            <Button Content="📊 Остатки" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#9C27B0"
                    Command="{Binding ViewStocksCommand}"/>
            <Button Content="🔄 Обновить" 
                    Style="{StaticResource ToolBarButtonStyle}"
                    Background="#607D8B"
                    Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="10,0,10,10"
                CornerRadius="4"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                         Padding="5"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 Поиск по номеру, контрагенту или основанию..." 
                                                             Foreground="Gray" 
                                                             Padding="5,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Период -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                    <DatePicker SelectedDate="{Binding StartDate}" 
                                Width="100" 
                                Margin="0,0,5,0"
                                FirstDayOfWeek="Monday"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="16"/>
                    <DatePicker SelectedDate="{Binding EndDate}" 
                                Width="100"
                                FirstDayOfWeek="Monday"/>
                </StackPanel>

                <!-- Фильтр по контрагенту -->
                <ComboBox Grid.Column="2" 
                          ItemsSource="{Binding Contractors}"
                          DisplayMemberPath="ShortName"
                          SelectedItem="{Binding SelectedContractorFilter}"
                          Margin="0,0,10,0"
                          Height="30"/>

                <!-- Чекбоксы статусов -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <CheckBox Content="Черновики" 
                              IsChecked="{Binding ShowDraft}"
                              Margin="0,0,15,0"
                              VerticalAlignment="Center"/>
                    <CheckBox Content="Проведенные" 
                              IsChecked="{Binding ShowPosted}"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица документов -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding FilteredReceipts}"
                  SelectedItem="{Binding SelectedReceipt}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  RowDetailsVisibilityMode="VisibleWhenSelected">

            <DataGrid.Columns>
                <!-- Статус -->
                <DataGridTemplateColumn Header="Статус" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3"
                                    Padding="5,2"
                                    Margin="2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Gray"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                <Setter Property="Background" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Draft">
                                                <Setter Property="Background" Value="#FF9800"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusDisplay}" 
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Номер -->
                <DataGridTextColumn Header="Номер" 
                                    Binding="{Binding Number}" 
                                    Width="100"/>

                <!-- Дата -->
                <DataGridTextColumn Header="Дата" 
                                    Binding="{Binding Date, StringFormat=dd.MM.yyyy}" 
                                    Width="80"/>

                <!-- Контрагент -->
                <DataGridTextColumn Header="Контрагент" 
                                    Binding="{Binding ContractorName}" 
                                    Width="200"/>

                <!-- Сумма -->
                <DataGridTextColumn Header="Сумма" 
                                    Binding="{Binding TotalAmount, StringFormat=N2}" 
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- НДС -->
                <DataGridTextColumn Header="НДС" 
                                    Binding="{Binding TotalVatAmount, StringFormat=N2}" 
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource NumericColumnStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Основание -->
                <DataGridTextColumn Header="Основание" 
                                    Binding="{Binding Basis}" 
                                    Width="150"/>

                <!-- Действия -->
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏️" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2196F3"
                                        Foreground="White"
                                        Command="{Binding DataContext.EditReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать"
                                        Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <Button Content="✅" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        Command="{Binding DataContext.PostReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Провести"
                                        Visibility="{Binding CanPost, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <Button Content="↩️" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#FF9800"
                                        Foreground="White"
                                        Command="{Binding DataContext.UnpostReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Отменить проведение"
                                        Visibility="{Binding CanUnpost, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <!-- Детали строки -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Контрагент:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ContractorDisplay}" Margin="0,0,20,5"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="ИНН:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ContractorINN, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Счет учета:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,20,5">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} - {1}">
                                        <Binding Path="CreditAccountCode"/>
                                        <Binding Path="CreditAccountName"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Место хранения:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding StorageLocationName, TargetNullValue='—'}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Примечание:" FontWeight="Bold" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Note, TargetNullValue='—'}" 
                                       TextWrapping="Wrap" Margin="0,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>