<Window x:Class="GlavnayaKniga.WPF.Views.EmployeeDismissWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Увольнение сотрудника" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

        <!-- Дата увольнения -->
        <TextBlock Grid.Row="1" Text="Дата увольнения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <DatePicker Grid.Row="2" 
                    SelectedDate="{Binding DismissalDate}"
                    Margin="0,0,0,10"
                    Height="30"
                    DisplayDateEnd="{x:Static system:DateTime.Today}"/>

        <!-- Номер приказа -->
        <TextBlock Grid.Row="3" Text="Номер приказа об увольнении:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="4" 
                 Text="{Binding OrderNumber, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 MaxLength="50"
                 Height="30"/>

        <!-- Причина увольнения -->
        <TextBlock Grid.Row="5" Text="Причина увольнения:" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="6" 
                 Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,20"
                 MaxLength="500"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="60"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Уволить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"
                    Background="#F44336"/>
            <Button Content="Отмена" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="5"
                    MinWidth="90"
                    Height="35"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="8"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                CornerRadius="6">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>