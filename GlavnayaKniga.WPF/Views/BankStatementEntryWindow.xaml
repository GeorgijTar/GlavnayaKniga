<Window x:Class="GlavnayaKniga.WPF.Views.BankStatementEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GlavnayaKniga.WPF.Converters"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{Binding Title}" Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Информация о документе -->
            <Border Grid.Row="0" 
                    Background="#F5F5F5" 
                    Padding="10" 
                    CornerRadius="4" 
                    Margin="0,0,0,15"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Документ:" FontWeight="Bold"/>
                        <TextBlock Text="Дата:" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="Сумма:" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="Направление:" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Entry.Note}"/>
                        <TextBlock Text="{Binding Entry.Date, StringFormat=dd.MM.yyyy}" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding Entry.Amount, StringFormat=N2}" Margin="0,5,0,0" FontWeight="Bold"/>
                        <TextBlock Text="{Binding IsIncoming, Converter={x:Static converters:DirectionTextConverter.Instance}}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Дата проводки -->
            <TextBlock Grid.Row="1" Text="Дата проводки:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <DatePicker Grid.Row="2" 
                        SelectedDate="{Binding Entry.Date}"
                        Margin="0,0,0,10"
                        DisplayDateEnd="{x:Static system:DateTime.Today}"
                        FirstDayOfWeek="Monday"/>

            <!-- Дебет счета -->
            <TextBlock Grid.Row="3" Text="Счет дебета:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" 
                          ItemsSource="{Binding Accounts}"
                          DisplayMemberPath="DisplayName"
                          SelectedItem="{Binding SelectedDebitAccount}"
                          Margin="0,0,5,10"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          Height="30"/>
                <Button Grid.Column="1" 
                        Content="⇄" 
                        Command="{Binding SwapAccountsCommand}"
                        Margin="0,0,0,10"
                        Padding="10,3"
                        FontSize="14"
                        Width="40"
                        Height="30"
                        ToolTip="Поменять местами счета"/>
            </Grid>

            <!-- Кредит счета -->
            <TextBlock Grid.Row="5" Text="Счет кредита:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="6" 
                      ItemsSource="{Binding Accounts}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedCreditAccount}"
                      Margin="0,0,0,10"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      Height="30"/>

            <!-- Сумма -->
            <TextBlock Grid.Row="7" Text="Сумма:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="8" 
                     Text="{Binding Entry.Amount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     PreviewTextInput="TextBox_PreviewTextInput"
                     MaxLength="15"
                     Height="30"/>

            <!-- Основание -->
            <TextBlock Grid.Row="9" Text="Основание:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="10" 
                      ItemsSource="{Binding Bases}"
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedBasis}"
                      Margin="0,0,0,15"
                      Height="30"/>

            <!-- Примечание (редактируемое) -->
            <TextBlock Grid.Row="11" Text="Примечание:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Grid.Row="12" 
                     Text="{Binding Entry.Note, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"
                     MaxLength="1000"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Создать проводку" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Margin="5"
                        MinWidth="120"
                        Height="35"
                        Background="#4CAF50"/>
                <Button Content="Отмена" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Margin="5"
                        MinWidth="90"
                        Height="35"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <Border Grid.RowSpan="14"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                    CornerRadius="6">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>